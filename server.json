{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.tradesearcher/mcp-server",
  "description": "Search TradeSearcher strategies and backtests from Claude Code, Cursor, Codex, and other agents.",
  "version": "0.1.1",
  "repository": {
    "url": "https://github.com/vnguyen42/tradesearcher-agent-tools",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@tradesearcher/mcp-server",
      "version": "0.1.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "TRADESEARCHER_API_KEY",
          "description": "Personal API key created at https://tradesearcher.ai/app/account/my-account#agent-api-keys",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
